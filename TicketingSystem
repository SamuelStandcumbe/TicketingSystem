        # Load existing log
        self.load_log()
        self.ticket_var.trace("w", lambda *args: self.load_log())  # update when ticket changes

    def get_selected_ticket(self):
        ticket_id = int(self.ticket_var.get().split(":")[0])
        return next(t for t in self.controller.tickets if t["ticket_id"] == ticket_id)

