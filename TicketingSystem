class CreateTicket(tk.Frame):
    def __init__(self, parent, controller):
        super().__init__(parent)
        self.controller = controller

        center_frame = tk.Frame(self)
        center_frame.place(relx=0.5, rely=0.5, anchor="center")

        tk.Label(center_frame, text="Create Ticket", font=("Arial", 16)).grid(row=0, column=0, columnspan=2, pady=10)
        # Input fields
        labels = ["Customer Name", "Department", "Contact Email/Extension",
                  "Issue Priority", "Issue Category", "Device Type and Asset Tag",
                  "Operating System", "Description", "Initial Diagnosis", "Skill Level"]
        self.entries = {}
        for i, label in enumerate(labels, start=1):
            tk.Label(center_frame, text=label).grid(row=i, column=0, sticky="e")
            entry = tk.Entry(center_frame)
            entry.grid(row=i, column=1)
            self.entries[label] = entry

        tk.Button(center_frame, text="Submit", command=self.submit_ticket).grid(row=13, column=0, columnspan=2, pady=10)
        tk.Button(center_frame, text="Back", command=lambda: controller.show_frame(MainMenu)).grid(row=14, column=0, columnspan=2, pady=5)

    def submit_ticket(self):

        now = datetime.now()

        data = {
            "date": now.strftime("%Y-%m-%d"),
            "time": now.strftime("%H:%M:%S"),
            "customer_name": self.entries["Customer Name"].get(),
            "department": self.entries["Department"].get(),
            "contact": self.entries["Contact Email/Extension"].get(),
            "priority": self.entries["Issue Priority"].get(),
            "issue_category": self.entries["Issue Category"].get(),
            "device_type": self.entries["Device Type and Asset Tag"].get(),
            "operating_system": self.entries["Operating System"].get(),
            "description": self.entries["Description"].get(),
            "skill_level": self.entries["Skill Level"].get(),
            "diagnosis": self.entries["Initial Diagnosis"].get()
        }
        
        
        customer_name = self.entries["Customer Name"].get()
        department = self.entries["Department"].get()
        priority = self.entries["Issue Priority"].get()
        
        # Validation
        if customer_name == "":
            messagebox.showerror("Input Error", "Customer Name is required")
            return

        if department == "":
            messagebox.showerror("Input Error", "Department is required")
            return

        if priority not in ["Low", "Medium", "High", "Critical"]:
            messagebox.showerror("Input Error", "Priority must be Low, Medium, High, or Critical")
            return
        
        # If validation passes, create ticket
        data = {label.lower().replace(" ", "_"): entry.get() for label, entry in self.entries.items()}
        self.controller.create_ticket(data)
        self.controller.show_frame(MainMenu)
        
        self.controller.create_ticket(data)
        self.clear_entries()  # <-- clear the form
        self.controller.show_frame(MainMenu)
        
    def clear_entries(self):
        for entry in self.entries.values():
            entry.delete(0, tk.END)

class LoadExistingTickets(tk.Toplevel):
    def __init__(self, controller):
        super().__init__()
        self.controller = controller
        self.title("Load Existing Tickets")
        self.geometry("900x650")
        self.resizable(True, True)

        tk.Label(self, text="Existing Tickets", font=("Arial", 16)).pack(pady=10)

        columns = ("id", "customer", "department", "priority", "status")
        self.tree = ttk.Treeview(self, columns=columns, show="headings", height=8)
        for col, name in zip(columns, ["Ticket ID", "Customer", "Department", "Priority", "Status"]):
            self.tree.heading(col, text=name)
            self.tree.column(col, width=120)
        self.tree.pack(fill="x", padx=10, pady=5)
        self.tree.bind("<<TreeviewSelect>>", self.select_ticket)

        # Details area
        detail_frame = tk.Frame(self)
        detail_frame.pack(fill="both", expand=True, padx=10, pady=10)

        canvas = tk.Canvas(detail_frame)
        scrollbar = tk.Scrollbar(detail_frame, orient="vertical", command=canvas.yview)
        canvas.configure(yscrollcommand=scrollbar.set)
        scrollbar.pack(side="right", fill="y")
        canvas.pack(side="left", fill="both", expand=True)

        self.details_inner = tk.Frame(canvas)
        canvas.create_window((0, 0), window=self.details_inner, anchor="nw")
        self.details_inner.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))

        tk.Button(self, text="Close", command=self.destroy).pack(pady=5)
        tk.Button(self, text="Delete Selected Ticket", command=self.delete_ticket).pack(pady=5)

        self.load_tickets()

    def load_tickets(self):
        for row in self.tree.get_children():
            self.tree.delete(row)
        for ticket in self.controller.tickets:
            self.tree.insert("", "end", values=(
                ticket["ticket_id"], ticket["customer_name"], ticket["department"],
                ticket["priority"], ticket["status"]
            ))

    def select_ticket(self, event):
        selected = self.tree.focus()
        if not selected:
            return
        values = self.tree.item(selected, "values")
        ticket_id = int(values[0])
        ticket = next((t for t in self.controller.tickets if t["ticket_id"] == ticket_id), None)
        if not ticket:
            return
        self.controller.current_ticket = ticket

        # Clear previous details
        for widget in self.details_inner.winfo_children():
            widget.destroy()

        # Display full ticket info
        tk.Label(self.details_inner, text=f"Ticket ID: {ticket['ticket_id']}", font=("Arial", 12, "bold")).pack(anchor="w")
        for key in ["date_logged", "time_logged", "customer_name", "department", "contact",
                    "priority", "issue_category", "device_type", "operating_system",
                    "skill_level", "description", "initial_diagnosis"]:
            tk.Label(self.details_inner, text=f"{key.replace('_',' ').title()}: {ticket[key]}").pack(anchor="w")
            
    def delete_ticket(self):
        selected = self.tree.focus()
        if not selected:
            messagebox.showerror("Error", "Select a ticket to delete")
            return

        values = self.tree.item(selected, "values")
        ticket_id = int(values[0])

        confirm = messagebox.askyesno("Confirm Delete", f"Are you sure you want to delete Ticket {ticket_id}?")
        if not confirm:
            return

        # Remove ticket from controller
        self.controller.tickets = [t for t in self.controller.tickets if t["ticket_id"] != ticket_id]
        self.controller.save_tickets()

        # Refresh treeview
        self.load_tickets()

        messagebox.showinfo("Deleted", f"Ticket {ticket_id} has been deleted.")

class AddInvestigation(tk.Toplevel):
    def __init__(self, controller):
        super().__init__()
        self.controller = controller
        self.title("Add Investigation")
        self.geometry("700x650")
        self.resizable(True, True)

        tk.Label(self, text="Add Investigation Step", font=("Arial", 16)).pack(pady=10)

        # Ticket selection
        tk.Label(self, text="Select Ticket:").pack(anchor="w", padx=10)
        ticket_ids = [f"{t['ticket_id']}: {t['customer_name']}" for t in self.controller.tickets]
        self.ticket_var = tk.StringVar()
        if ticket_ids:
            self.ticket_var.set(ticket_ids[0])
        self.ticket_dropdown = tk.OptionMenu(self, self.ticket_var, *ticket_ids)
        self.ticket_dropdown.pack(fill="x", padx=10, pady=5)

        # Investigation Step Inputs
        tk.Label(self, text="Step Description:").pack(anchor="w", padx=10)
        self.step_entry = tk.Entry(self)
        self.step_entry.pack(fill="x", padx=10, pady=5)

        tk.Label(self, text="Tool Used:").pack(anchor="w", padx=10)
        self.tool_entry = tk.Entry(self)
        self.tool_entry.pack(fill="x", padx=10, pady=5)

        self.screenshot_var = tk.StringVar()
        tk.Button(self, text="Select Screenshot", command=self.select_screenshot).pack(anchor="w", padx=10, pady=5)
        self.screenshot_label = tk.Label(self, text="No screenshot selected")
        self.screenshot_label.pack(anchor="w", padx=10, pady=2)

        # State for editing steps
        self.edit_index = None
        
        # Buttons
        tk.Button(self, text="Add Step", command=self.add_step).pack(pady=5)
        tk.Button(self, text="Save Investigation", command=self.save_investigation).pack(pady=5)
        tk.Button(self, text="Remove Selected Step", command=self.remove_step).pack(pady=5)
        tk.Button(self, text="View Evidence", command=self.view_evidence).pack(pady=5)
        tk.Button(self, text="Edit Selected Step", command=self.edit_step).pack(pady=5)

        # List of steps for selected ticket
        tk.Label(self, text="Current Steps:").pack(anchor="w", padx=10, pady=5)
        self.steps_listbox = tk.Listbox(self)
        self.steps_listbox.pack(fill="both", expand=True, padx=10, pady=5)

        tk.Button(self, text="Close", command=self.destroy).pack(pady=5)

        # Load steps if ticket is selected
        self.load_steps()
        self.ticket_var.trace("w", lambda *args: self.load_steps())  # update listbox when ticket changes

    def select_screenshot(self):
        file_path = filedialog.askopenfilename(title="Select Screenshot",
                                               filetypes=[("Image Files", "*.png *.jpg *.jpeg *.gif")])
        if file_path:
            self.screenshot_var.set(file_path)
            self.screenshot_label.config(text=os.path.basename(file_path))

    def get_selected_ticket(self):
        ticket_id = int(self.ticket_var.get().split(":")[0])
        return next(t for t in self.controller.tickets if t["ticket_id"] == ticket_id)

    def load_steps(self):
        self.steps_listbox.delete(0, tk.END)
        ticket = self.get_selected_ticket()

        for idx, step in enumerate(ticket.get("investigation_steps", []), start=1):

            screenshot_path = step.get("screenshot_path")

            if screenshot_path:
                screenshot_name = os.path.basename(screenshot_path)
            else:
                screenshot_name = "None"

            display = f"{idx}. [{step.get('timestamp','')}] {step['description']} (Tool: {step['tool']}, Screenshot: {screenshot_name})"

            self.steps_listbox.insert(tk.END, display)

    def add_step(self):

        ticket = self.get_selected_ticket()

        step_data = {
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "description": self.step_entry.get(),
            "tool": self.tool_entry.get(),
            "screenshot_path": None
        }

        # Copy screenshot if selected
        if self.screenshot_var.get():

            dest_dir = IMAGE_FOLDER
            os.makedirs(dest_dir, exist_ok=True)

            src = self.screenshot_var.get()
            filename = f"{ticket['ticket_id']}_{len(ticket.get('investigation_steps', []))}_{os.path.basename(src)}"
            dest = os.path.join(dest_dir, filename)

            shutil.copy(src, dest)

            step_data["screenshot_path"] = dest

        if "investigation_steps" not in ticket:
            ticket["investigation_steps"] = []

        # If editing existing step
        if self.edit_index is not None:
            ticket["investigation_steps"][self.edit_index] = step_data
            self.edit_index = None

        else:
            ticket["investigation_steps"].append(step_data)

        self.controller.save_tickets()
        self.load_steps()

        # Clear inputs
        self.step_entry.delete(0, tk.END)
        self.tool_entry.delete(0, tk.END)
        self.screenshot_var.set("")
        self.screenshot_label.config(text="No screenshot selected")

    def edit_step(self):

        selected = self.steps_listbox.curselection()

        if not selected:
            messagebox.showerror("Error", "Select a step to edit")
            return

        idx = selected[0]

        ticket = self.get_selected_ticket()

        step = ticket["investigation_steps"][idx]

        self.step_entry.delete(0, tk.END)
        self.step_entry.insert(0, step["description"])

        self.tool_entry.delete(0, tk.END)
        self.tool_entry.insert(0, step["tool"])

        if step.get("screenshot_path"):
            self.screenshot_var.set(step["screenshot_path"])
            self.screenshot_label.config(text=os.path.basename(step["screenshot_path"]))

        self.edit_index = idx
    
    def remove_step(self):
        ticket = self.get_selected_ticket()
        selected = self.steps_listbox.curselection()
        if selected:
            idx = selected[0]
            # Optionally delete the screenshot file
            screenshot_path = ticket["investigation_steps"][idx].get("screenshot_path")
            if screenshot_path and os.path.exists(screenshot_path):
                os.remove(screenshot_path)
            ticket["investigation_steps"].pop(idx)
            self.controller.save_tickets()
            self.load_steps()
            
    def view_evidence(self):

        selected = self.steps_listbox.curselection()

        if not selected:
            messagebox.showerror("Error", "Please select an investigation step")
            return

        idx = selected[0]

        ticket = self.get_selected_ticket()

        step = ticket["investigation_steps"][idx]

        image_path = step.get("screenshot_path")

        if not image_path or not os.path.exists(image_path):
            messagebox.showerror("No Image", "No screenshot attached to this step")
            return

        # Create new window
        img_window = tk.Toplevel(self)
        img_window.title("Evidence Image")

        # Load image
        img = Image.open(image_path)

        # Resize large images
        img.thumbnail((800, 600))

        photo = ImageTk.PhotoImage(img)

        label = tk.Label(img_window, image=photo)
        label.image = photo
        label.pack()

    def save_investigation(self):
        ticket = self.get_selected_ticket()

        if not self.ticket_var.get():
            messagebox.showerror("Error", "Please select a ticket")
            return

        if "investigation_steps" not in ticket or len(ticket["investigation_steps"]) == 0:
            messagebox.showerror("Error", "You must add at least one investigation step")
            return

        self.controller.save_tickets()
        messagebox.showinfo("Saved", "Investigation saved successfully")

class AddResolution(tk.Toplevel):
    def __init__(self, controller):
        super().__init__()
        self.controller = controller
        self.title("Add Resolution")
        self.geometry("700x700")
        self.resizable(True, True)

        tk.Label(self, text="Add Resolution", font=("Arial", 16)).pack(pady=10)

        # Ticket selection
        tk.Label(self, text="Select Ticket:").pack(anchor="w", padx=10)
        ticket_ids = [f"{t['ticket_id']}: {t['customer_name']}" for t in self.controller.tickets]
        self.ticket_var = tk.StringVar()
        if ticket_ids:
            self.ticket_var.set(ticket_ids[0])
        self.ticket_dropdown = tk.OptionMenu(self, self.ticket_var, *ticket_ids)
        self.ticket_dropdown.pack(fill="x", padx=10, pady=5)

        # Actions Taken
        tk.Label(self, text="Actions Taken:").pack(anchor="w", padx=10, pady=5)
        self.action_vars = {}
        actions = [
            "Updated OS",
            "Freed Disk Space",
            "Removed Apps",
            "Added RAM",
            "Reset Time Service",
            "Clean Install",
            "External Storage Added"
        ]
        for action in actions:
            var = tk.BooleanVar()
            tk.Checkbutton(self, text=action, variable=var).pack(anchor="w", padx=20)
            self.action_vars[action] = var

        # Detailed Explanation
        tk.Label(self, text="Detailed Explanation of Fix:").pack(anchor="w", padx=10, pady=5)
        self.explanation_text = tk.Text(self, height=5)
        self.explanation_text.pack(fill="x", padx=10, pady=5)

        # Performance Comparison
        tk.Label(self, text="Before & After Performance Comparison:", font=("Arial", 12, "bold")).pack(anchor="w", padx=10, pady=5)
        perf_frame = tk.Frame(self)
        perf_frame.pack(fill="x", padx=10, pady=5)

        tk.Label(perf_frame, text="Performance Area").grid(row=0, column=0, padx=5)
        tk.Label(perf_frame, text="Before").grid(row=0, column=1, padx=5)
        tk.Label(perf_frame, text="After").grid(row=0, column=2, padx=5)

        self.perf_vars = {}
        areas = ["CPU Usage (%)", "Disk Space (GB Free)", "RAM Usage (%)"]
        for i, area in enumerate(areas, start=1):
            tk.Label(perf_frame, text=area).grid(row=i, column=0, sticky="w", padx=5, pady=2)
            before_var = tk.StringVar()
            after_var = tk.StringVar()
            tk.Entry(perf_frame, textvariable=before_var, width=10).grid(row=i, column=1, padx=5)
            tk.Entry(perf_frame, textvariable=after_var, width=10).grid(row=i, column=2, padx=5)
            self.perf_vars[area] = {"before": before_var, "after": after_var}

        self.edit_mode = False

        # Buttons
        tk.Button(self, text="Save Resolution", command=self.save_resolution).pack(pady=10)
        tk.Button(self, text="Close", command=self.destroy).pack(pady=5)
        tk.Button(self, text="Edit Resolution", command=self.enable_edit).pack(pady=5)

        self.load_resolution()

        self.ticket_var.trace("w", lambda *args: self.load_resolution())  # reload when ticket changes

    def enable_edit(self):

        self.edit_mode = True

        self.explanation_text.config(state="normal")

        for area in self.perf_vars:
            self.perf_vars[area]["before"].set(self.perf_vars[area]["before"].get())
            self.perf_vars[area]["after"].set(self.perf_vars[area]["after"].get())

        messagebox.showinfo("Edit Mode", "Resolution editing enabled")

    def get_selected_ticket(self):
        ticket_id = int(self.ticket_var.get().split(":")[0])
        return next(t for t in self.controller.tickets if t["ticket_id"] == ticket_id)

    def load_resolution(self):
        ticket = self.get_selected_ticket()
        actions = ticket.get("actions_taken", {})
        for action, var in self.action_vars.items():
            var.set(actions.get(action, False))

        self.explanation_text.delete("1.0", tk.END)
        self.explanation_text.insert(tk.END, ticket.get("resolution_explanation", ""))

        perf_data = ticket.get("performance_data", {})
        for area, vals in self.perf_vars.items():
            vals["before"].set(perf_data.get(area, {}).get("before", ""))
            vals["after"].set(perf_data.get(area, {}).get("after", ""))

    def save_resolution(self):
        ticket = self.get_selected_ticket()
        ticket["actions_taken"] = {action: var.get() for action, var in self.action_vars.items()}
        ticket["resolution_explanation"] = self.explanation_text.get("1.0", tk.END).strip()
        ticket["performance_data"] = {area: {"before": vals["before"].get(), "after": vals["after"].get()} for area, vals in self.perf_vars.items()}
        self.controller.save_tickets()
        tk.messagebox.showinfo("Saved", f"Resolution saved for Ticket {ticket['ticket_id']}")

class AddCommunication(tk.Toplevel):
    def __init__(self, controller):
        super().__init__()

        self.controller = controller
        self.title("Add Communication")
        self.geometry("700x650")
        self.resizable(True, True)

        tk.Label(self, text="Add Communication Entry", font=("Arial", 16)).pack(pady=10)

        # Ticket selection dropdown
        tk.Label(self, text="Select Ticket:").pack(anchor="w", padx=10)
        ticket_ids = [f"{t['ticket_id']}: {t['customer_name']}" for t in self.controller.tickets]
        self.ticket_var = tk.StringVar()
        if ticket_ids:
            self.ticket_var.set(ticket_ids[0])
        self.ticket_dropdown = tk.OptionMenu(self, self.ticket_var, *ticket_ids)
        self.ticket_dropdown.pack(fill="x", padx=10, pady=5)

        # Communication input fields
        tk.Label(self, text="Date:").pack(anchor="w", padx=10)
        self.date_entry = tk.Entry(self)
        self.date_entry.pack(fill="x", padx=10, pady=5)

        tk.Label(self, text="Method (Email/Phone/In-person):").pack(anchor="w", padx=10)
        self.method_entry = tk.Entry(self)
        self.method_entry.pack(fill="x", padx=10, pady=5)

        tk.Label(self, text="Summary of Interaction:").pack(anchor="w", padx=10)
        self.summary_text = tk.Text(self, height=5)
        self.summary_text.pack(fill="both", padx=10, pady=5)

        self.edit_index = None

        # Buttons
        tk.Button(self, text="Add Entry", command=self.add_entry).pack(pady=5)
        tk.Button(self, text="Remove Selected Entry", command=self.remove_entry).pack(pady=5)
        tk.Button(self, text="Edit Selected Entry", command=self.edit_entry).pack(pady=5)

        tk.Label(self, text="Current Communication Log:").pack(anchor="w", padx=10, pady=5)
        self.log_listbox = tk.Listbox(self)
        self.log_listbox.pack(fill="both", expand=True, padx=10, pady=5)

        tk.Button(self, text="Close", command=self.destroy).pack(pady=5)

        # Load existing log
        self.load_log()
        self.ticket_var.trace("w", lambda *args: self.load_log())  # update when ticket changes

    def get_selected_ticket(self):
        ticket_id = int(self.ticket_var.get().split(":")[0])
        return next(t for t in self.controller.tickets if t["ticket_id"] == ticket_id)

    def load_log(self):
        self.log_listbox.delete(0, tk.END)
        ticket = self.get_selected_ticket()
        for idx, entry in enumerate(ticket.get("communication_log", []), start=1):
            display = f"{idx}. [{entry.get('timestamp','')}] {entry['method']} - {entry['summary'][:30]}..."
            self.log_listbox.insert(tk.END, display)

    def add_entry(self):

        ticket = self.get_selected_ticket()

        entry = {
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "date": self.date_entry.get(),
            "method": self.method_entry.get(),
            "summary": self.summary_text.get("1.0", tk.END).strip()
        }   

        if "communication_log" not in ticket:
            ticket["communication_log"] = []

        if self.edit_index is not None:
            ticket["communication_log"][self.edit_index] = entry
            self.edit_index = None
        else:
            ticket["communication_log"].append(entry)

        self.controller.save_tickets()
        self.load_log()

        # Clear inputs
        self.date_entry.delete(0, tk.END)
        self.method_entry.delete(0, tk.END)
        self.summary_text.delete("1.0", tk.END)

    def edit_entry(self):

        selected = self.log_listbox.curselection()

        if not selected:
            messagebox.showerror("Error", "Select an entry to edit")
            return

        idx = selected[0]

        ticket = self.get_selected_ticket()
        entry = ticket["communication_log"][idx]

        self.date_entry.delete(0, tk.END)
        self.date_entry.insert(0, entry["date"])

        self.method_entry.delete(0, tk.END)
        self.method_entry.insert(0, entry["method"])

        self.summary_text.delete("1.0", tk.END)
        self.summary_text.insert(tk.END, entry["summary"])

        self.edit_index = idx

    def remove_entry(self):
        ticket = self.get_selected_ticket()
        selected = self.log_listbox.curselection()
        if selected:
            idx = selected[0]
            ticket["communication_log"].pop(idx)
            self.controller.save_tickets()
            self.load_log()

class ViewTicket(tk.Toplevel):

    def __init__(self, controller):

        super().__init__()

        self.controller = controller

        self.title("Full Ticket Viewer")

        self.geometry("900x700")

        tk.Label(self, text="Full Ticket Viewer", font=("Arial", 16)).pack(pady=10)

        # Ticket selector
        tk.Label(self, text="Select Ticket:").pack(anchor="w", padx=10)

        ticket_ids = [f"{t['ticket_id']}: {t['customer_name']}" for t in controller.tickets]

        self.ticket_var = tk.StringVar()

        if ticket_ids:
            self.ticket_var.set(ticket_ids[0])

        dropdown = tk.OptionMenu(self, self.ticket_var, *ticket_ids)

        dropdown.pack(fill="x", padx=10, pady=5)

        tk.Button(self, text="Load Ticket", command=self.load_ticket).pack(pady=5)

        # Scrollable area
        canvas = tk.Canvas(self)

        scrollbar = tk.Scrollbar(self, orient="vertical", command=canvas.yview)

        canvas.configure(yscrollcommand=scrollbar.set)

        scrollbar.pack(side="right", fill="y")

        canvas.pack(side="left", fill="both", expand=True)

        self.content = tk.Frame(canvas)

        canvas.create_window((0,0), window=self.content, anchor="nw")

        self.content.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))

    def get_selected_ticket(self):

        ticket_id = int(self.ticket_var.get().split(":")[0])

        return next(t for t in self.controller.tickets if t["ticket_id"] == ticket_id)

    def load_ticket(self):

        for widget in self.content.winfo_children():
            widget.destroy()

        ticket = self.get_selected_ticket()

        # Ticket Details
        tk.Label(self.content, text="Ticket Details", font=("Arial", 14, "bold")).pack(anchor="w", pady=5)

        details = [
            "date_logged", "time_logged", "customer_name", "department",
            "contact", "priority", "issue_category", "device_type",
            "operating_system", "skill_level", "description",
            "initial_diagnosis", "status"
        ]

        for key in details:
            tk.Label(self.content,
                     text=f"{key.replace('_',' ').title()}: {ticket.get(key,'')}").pack(anchor="w")

        # Investigation
        tk.Label(self.content, text="Investigation Steps", font=("Arial", 14, "bold")).pack(anchor="w", pady=10)

        for i, step in enumerate(ticket.get("investigation_steps", []), start=1):

            screenshot = "Yes" if step.get("screenshot_path") else "No"

            tk.Label(self.content,
                     text=f"{i}. {step['description']} (Tool: {step['tool']}, Evidence: {screenshot})"
                     ).pack(anchor="w")

        # Communication
        tk.Label(self.content, text="Communication Log", font=("Arial", 14, "bold")).pack(anchor="w", pady=10)

        for entry in ticket.get("communication_log", []):

            tk.Label(self.content,
                     text=f"{entry['date']} | {entry['method']} | {entry['summary']}"
                     ).pack(anchor="w")

        # Resolution
        tk.Label(self.content, text="Resolution", font=("Arial", 14, "bold")).pack(anchor="w", pady=10)

        actions = ticket.get("actions_taken", {})

        for action, value in actions.items():
            if value:
                tk.Label(self.content, text=f"✔ {action}").pack(anchor="w")

        tk.Label(self.content,
                 text=f"Explanation: {ticket.get('resolution_explanation','')}"
                 ).pack(anchor="w")

        # Performance Data
        tk.Label(self.content, text="Performance Comparison", font=("Arial", 14, "bold")).pack(anchor="w", pady=10)

        for area, vals in ticket.get("performance_data", {}).items():

            before = vals.get("before", "")

            after = vals.get("after", "")

            tk.Label(self.content,
                     text=f"{area}: Before {before} → After {after}"
                     ).pack(anchor="w")

class CloseTicket(tk.Toplevel):
    def __init__(self, controller):
        super().__init__()

        self.controller = controller
        self.title("Close Ticket / Manage Tickets")
        self.geometry("800x600")
        self.resizable(True, True)

        tk.Label(self, text="Close Ticket / Manage Tickets", font=("Arial", 16)).pack(pady=10)

        # --- Open Tickets Section ---
        tk.Label(self, text="Open Tickets:").pack(anchor="w", padx=10)
        self.open_ticket_var = tk.StringVar()

        # Placeholder in case no open tickets exist
        initial_open = "No open tickets"
        self.open_ticket_var.set(initial_open)
        self.open_ticket_dropdown = tk.OptionMenu(self, self.open_ticket_var, initial_open)
        self.open_ticket_dropdown.pack(fill="x", padx=10, pady=5)

        tk.Label(self, text="Final Resolution / Notes:").pack(anchor="w", padx=10)
        self.resolution_text = tk.Text(self, height=6)
        self.resolution_text.pack(fill="both", padx=10, pady=5)

        tk.Label(self, text="Performance Notes:").pack(anchor="w", padx=10)
        self.performance_text = tk.Text(self, height=4)
        self.performance_text.pack(fill="both", padx=10, pady=5)

        tk.Button(self, text="Close Ticket", command=self.close_ticket).pack(pady=5)

        # --- Closed Tickets Section ---
        tk.Label(self, text="Closed Tickets:").pack(anchor="w", padx=10, pady=10)
        self.closed_listbox = tk.Listbox(self)
        self.closed_listbox.pack(fill="both", expand=True, padx=10, pady=5)

        tk.Button(self, text="Delete Selected Closed Ticket", command=self.delete_ticket).pack(pady=5)
        tk.Button(self, text="Close Window", command=self.destroy).pack(pady=5)

        # Populate lists
        self.update_closed_list()
        self.refresh_open_dropdown()

        # Load first open ticket if available
        self.open_ticket_var.trace("w", lambda *args: self.load_open_ticket_details())
        self.load_open_ticket_details()

    # Get currently selected open ticket
    def get_selected_open_ticket(self):
        value = self.open_ticket_var.get()
        if not value or "No open tickets" in value:
            return None
        ticket_id = int(value.split(":")[0])
        return next((t for t in self.controller.tickets if t["ticket_id"] == ticket_id), None)

    # Load open ticket details into text fields
    def load_open_ticket_details(self):
        ticket = self.get_selected_open_ticket()
        self.resolution_text.delete("1.0", tk.END)
        self.performance_text.delete("1.0", tk.END)
        if ticket:
            self.resolution_text.insert(tk.END, ticket.get("final_resolution", ""))
            self.performance_text.insert(tk.END, ticket.get("performance_notes", ""))

    # Close ticket and update status
    def close_ticket(self):
        ticket = self.get_selected_open_ticket()
        if not ticket:
            tk.messagebox.showwarning("No Ticket", "No open ticket selected to close.")
            return
        ticket["status"] = "Closed"
        ticket["final_resolution"] = self.resolution_text.get("1.0", tk.END).strip()
        ticket["performance_notes"] = self.performance_text.get("1.0", tk.END).strip()
        self.controller.save_tickets()
        self.update_closed_list()
        self.refresh_open_dropdown()
        tk.messagebox.showinfo("Ticket Closed", f"Ticket {ticket['ticket_id']} has been closed.")

    # Populate closed tickets listbox
    def update_closed_list(self):
        self.closed_listbox.delete(0, tk.END)
        for ticket in self.controller.tickets:
            if ticket['status'] == "Closed":
                self.closed_listbox.insert(tk.END, f"{ticket['ticket_id']}: {ticket['customer_name']}")

    # Refresh open tickets dropdown safely
    def refresh_open_dropdown(self):
        open_ticket_ids = [f"{t['ticket_id']}: {t['customer_name']} (Status: {t['status']})"
                           for t in self.controller.tickets if t['status'] != "Closed"]
        menu = self.open_ticket_dropdown["menu"]
        menu.delete(0, "end")
        if open_ticket_ids:
            for t in open_ticket_ids:
                menu.add_command(label=t, command=lambda value=t: self.open_ticket_var.set(value))
            self.open_ticket_var.set(open_ticket_ids[0])
        else:
            placeholder = "No open tickets"
            menu.add_command(label=placeholder, command=lambda: self.open_ticket_var.set(placeholder))
            self.open_ticket_var.set(placeholder)

    # Delete selected closed ticket
    def delete_ticket(self):
        selection = self.closed_listbox.curselection()
        if not selection:
            return
        idx = selection[0]
        ticket_text = self.closed_listbox.get(idx)
        ticket_id = int(ticket_text.split(":")[0])
        # Remove ticket from controller
        self.controller.tickets = [t for t in self.controller.tickets if t['ticket_id'] != ticket_id]
        self.controller.save_tickets()
        self.update_closed_list()
        tk.messagebox.showinfo("Deleted", f"Ticket {ticket_id} has been deleted.")
                
