        self.log_listbox.delete(0, tk.END)
        ticket = self.get_selected_ticket()
        for idx, entry in enumerate(ticket.get("communication_log", []), start=1):
            display = f"{idx}. Date: {entry['date']}, Method: {entry['method']}, Summary: {entry['summary'][:30]}..."
            self.log_listbox.insert(tk.END, display)

    def add_entry(self):
        ticket = self.get_selected_ticket()
        entry = {
            "date": self.date_entry.get(),
            "method": self.method_entry.get(),
            "summary": self.summary_text.get("1.0", tk.END).strip()
        }
        if "communication_log" not in ticket:
            ticket["communication_log"] = []
        ticket["communication_log"].append(entry)
        self.controller.save_tickets()
        self.load_log()
        # Clear fields
        self.date_entry.delete(0, tk.END)
        self.method_entry.delete(0, tk.END)
        self.summary_text.delete("1.0", tk.END)

    def remove_entry(self):
        ticket = self.get_selected_ticket()
        selected = self.log_listbox.curselection()
        if selected:
            idx = selected[0]
            ticket["communication_log"].pop(idx)
            self.controller.save_tickets()
            self.load_log()

class CloseTicket(tk.Toplevel):
    def __init__(self, controller):
        super().__init__()

        self.controller = controller
        self.title("Close Ticket / Manage Tickets")
        self.geometry("800x600")
        self.resizable(True, True)

        tk.Label(self, text="Close Ticket / Manage Tickets", font=("Arial", 16)).pack(pady=10)

        # --- Open Tickets Section ---
        tk.Label(self, text="Open Tickets:").pack(anchor="w", padx=10)
        self.open_ticket_var = tk.StringVar()

        # Placeholder in case no open tickets exist
        initial_open = "No open tickets"
        self.open_ticket_var.set(initial_open)
        self.open_ticket_dropdown = tk.OptionMenu(self, self.open_ticket_var, initial_open)
        self.open_ticket_dropdown.pack(fill="x", padx=10, pady=5)

        tk.Label(self, text="Final Resolution / Notes:").pack(anchor="w", padx=10)
        self.resolution_text = tk.Text(self, height=6)
        self.resolution_text.pack(fill="both", padx=10, pady=5)

        tk.Label(self, text="Performance Notes:").pack(anchor="w", padx=10)
        self.performance_text = tk.Text(self, height=4)
        self.performance_text.pack(fill="both", padx=10, pady=5)

        tk.Button(self, text="Close Ticket", command=self.close_ticket).pack(pady=5)

        # --- Closed Tickets Section ---
        tk.Label(self, text="Closed Tickets:").pack(anchor="w", padx=10, pady=10)
        self.closed_listbox = tk.Listbox(self)
        self.closed_listbox.pack(fill="both", expand=True, padx=10, pady=5)

        tk.Button(self, text="Delete Selected Closed Ticket", command=self.delete_ticket).pack(pady=5)
        tk.Button(self, text="Close Window", command=self.destroy).pack(pady=5)

        # Populate lists
        self.update_closed_list()
        self.refresh_open_dropdown()

        # Load first open ticket if available
        self.open_ticket_var.trace("w", lambda *args: self.load_open_ticket_details())
        self.load_open_ticket_details()

    # Get currently selected open ticket
    def get_selected_open_ticket(self):
        value = self.open_ticket_var.get()
        if not value or "No open tickets" in value:
            return None
        ticket_id = int(value.split(":")[0])
        return next((t for t in self.controller.tickets if t["ticket_id"] == ticket_id), None)

    # Load open ticket details into text fields
    def load_open_ticket_details(self):
        ticket = self.get_selected_open_ticket()
        self.resolution_text.delete("1.0", tk.END)
        self.performance_text.delete("1.0", tk.END)
        if ticket:
            self.resolution_text.insert(tk.END, ticket.get("final_resolution", ""))
            self.performance_text.insert(tk.END, ticket.get("performance_notes", ""))

    # Close ticket and update status
    def close_ticket(self):
        ticket = self.get_selected_open_ticket()
        if not ticket:
            tk.messagebox.showwarning("No Ticket", "No open ticket selected to close.")
            return
        ticket["status"] = "Closed"
        ticket["final_resolution"] = self.resolution_text.get("1.0", tk.END).strip()
        ticket["performance_notes"] = self.performance_text.get("1.0", tk.END).strip()
        self.controller.save_tickets()
        self.update_closed_list()
        self.refresh_open_dropdown()
        tk.messagebox.showinfo("Ticket Closed", f"Ticket {ticket['ticket_id']} has been closed.")

    # Populate closed tickets listbox
    def update_closed_list(self):
        self.closed_listbox.delete(0, tk.END)
        for ticket in self.controller.tickets:
            if ticket['status'] == "Closed":
                self.closed_listbox.insert(tk.END, f"{ticket['ticket_id']}: {ticket['customer_name']}")

    # Refresh open tickets dropdown safely
    def refresh_open_dropdown(self):
        open_ticket_ids = [f"{t['ticket_id']}: {t['customer_name']} (Status: {t['status']})"
                           for t in self.controller.tickets if t['status'] != "Closed"]
        menu = self.open_ticket_dropdown["menu"]
        menu.delete(0, "end")
        if open_ticket_ids:
            for t in open_ticket_ids:
                menu.add_command(label=t, command=lambda value=t: self.open_ticket_var.set(value))
            self.open_ticket_var.set(open_ticket_ids[0])
        else:
            placeholder = "No open tickets"
            menu.add_command(label=placeholder, command=lambda: self.open_ticket_var.set(placeholder))
            self.open_ticket_var.set(placeholder)

    # Delete selected closed ticket
    def delete_ticket(self):
        selection = self.closed_listbox.curselection()
        if not selection:
            return
        idx = selection[0]
        ticket_text = self.closed_listbox.get(idx)
        ticket_id = int(ticket_text.split(":")[0])
        # Remove ticket from controller
        self.controller.tickets = [t for t in self.controller.tickets if t['ticket_id'] != ticket_id]
        self.controller.save_tickets()
        self.update_closed_list()
        tk.messagebox.showinfo("Deleted", f"Ticket {ticket_id} has been deleted.")
                
if __name__ == "__main__":
    app = TicketApp()
    app.mainloop()
